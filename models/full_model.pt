import torch
import torch.nn as nn


class FullModel(nn.Module):
    def __init__(self, autoencoder, transformer):
        super().__init__()
        self.autoencoder = autoencoder
        self.transformer = transformer

    def forward(self, x_seq):
        """
        x_seq shape: (batch, seq_len, input_dim)
        """
        batch_size, seq_len, input_dim = x_seq.shape

        x_flat = x_seq.view(batch_size * seq_len, input_dim)

        z, x_hat = self.autoencoder(x_flat)
        recon_error = torch.mean((x_flat - x_hat) ** 2, dim=1, keepdim=True)
        combined = torch.cat([z, recon_error], dim=1)

        combined = combined.view(batch_size, seq_len, -1)

        logits = self.transformer(combined)
        return logits